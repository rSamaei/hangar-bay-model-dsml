airfield ConflictDemo_Airfield {
  // =========================================================================
  // AIRCRAFT TYPES
  // =========================================================================
  
  aircraft F35_Lightning {
    wingspan 10.7m
    length 15.6m
    height 4.4m
    tailHeight 4.4m
  }

  aircraft Typhoon_FGR4 {
    wingspan 11.0m
    length 15.96m
    height 5.28m
    tailHeight 5.28m
  }

  aircraft Hawk_T2 {
    wingspan 9.9m
    length 12.4m
    height 4.0m
    tailHeight 4.0m
  }

  aircraft Apache_AH64 {
    wingspan 14.6m
    length 17.7m
    height 4.9m
    tailHeight 4.9m
  }

  // =========================================================================
  // HANGAR - Small facility with limited capacity
  // =========================================================================
  
  hangar MaintenanceHangar {
    doorWidth 25.0m
    doorHeight 8.0m
    grid baygrid {
      bay Bay1 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { Bay2 }
      }
      bay Bay2 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { Bay1 Bay3 }
      }
      bay Bay3 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { Bay2 }
      }
    }
  }

  hangar HelicopterHangar {
    doorWidth 20.0m
    doorHeight 7.0m
    grid baygrid {
      bay Heli_Bay1 {
        width 18.0m
        depth 20.0m
        height 7.0m
      }
    }
  }

  // =========================================================================
  // CONFLICTING INDUCTIONS - December 12, 2025
  // =========================================================================

  // CONFLICT 1: Three aircraft fighting for Bay1 at the same time
  induct F35_Lightning into Bay1 from 2025-12-12T08:00 to 2025-12-12T16:00;
  induct Typhoon_FGR4 into Bay1 from 2025-12-12T10:00 to 2025-12-12T14:00;  // OVERLAPS!
  induct Hawk_T2 into Bay1 from 2025-12-12T12:00 to 2025-12-12T18:00;       // OVERLAPS!

  // CONFLICT 2: Overlapping shifts in Bay2
  induct F35_Lightning into Bay2 from 2025-12-12T06:00 to 2025-12-12T12:00;
  induct F35_Lightning into Bay2 from 2025-12-12T11:00 to 2025-12-12T17:00; // OVERLAPS by 1 hour!

  // CONFLICT 3: Back-to-back gone wrong in Bay3
  induct Typhoon_FGR4 into Bay3 from 2025-12-12T08:00 to 2025-12-12T14:00;
  induct Hawk_T2 into Bay3 from 2025-12-12T13:30 to 2025-12-12T19:00;       // OVERLAPS by 30 min!

  // Valid induction in helicopter hangar (no conflict)
  induct Apache_AH64 into Heli_Bay1 from 2025-12-12T09:00 to 2025-12-12T17:00;

  // CONFLICT 4: Next day overlaps
  induct F35_Lightning into Bay1 from 2025-12-13T14:00 to 2025-12-13T22:00;
  induct Typhoon_FGR4 into Bay1 from 2025-12-13T20:00 to 2025-12-14T04:00;  // OVERLAPS 2 hours!

  // CONFLICT 5: Multi-bay occupation with overlap
  induct F35_Lightning into Bay2 Bay3 from 2025-12-14T08:00 to 2025-12-14T16:00;
  induct Hawk_T2 into Bay3 from 2025-12-14T10:00 to 2025-12-14T14:00;       // OVERLAPS Bay3!

  // =========================================================================
  // AUTO-SCHEDULED INDUCTIONS - Will struggle to find slots
  // =========================================================================

  // These will have difficulty finding space due to all the conflicts above
  auto-induct F35_Lightning duration 480 minutes prefer MaintenanceHangar;
  auto-induct Typhoon_FGR4 duration 360 minutes prefer MaintenanceHangar;
  auto-induct Hawk_T2 duration 240 minutes prefer MaintenanceHangar;
  auto-induct Apache_AH64 duration 300 minutes prefer HelicopterHangar;
  
  // This one will likely fail - helicopter too wide for maintenance hangar
  auto-induct Apache_AH64 duration 180 minutes prefer MaintenanceHangar;
}