airfield RAF_Maintenance_Base {
  // =========================================================================
  // AIRCRAFT TYPES - Various military and civilian aircraft
  // =========================================================================
  
  aircraft F35_Lightning {
    wingspan 10.7m
    length 15.6m
    height 4.4m
    tailHeight 4.4m
  }

  aircraft Typhoon_FGR4 {
    wingspan 11.0m
    length 15.96m
    height 5.28m
    tailHeight 5.28m
  }

  aircraft C130_Hercules {
    wingspan 40.4m
    length 29.8m
    height 11.7m
    tailHeight 11.7m
  }

  aircraft A400M_Atlas {
    wingspan 42.4m
    length 45.1m
    height 14.7m
    tailHeight 14.7m
  }

  aircraft Apache_AH64 {
    wingspan 14.6m
    length 17.7m
    height 4.9m
    tailHeight 4.9m
  }

  aircraft Chinook_HC6 {
    wingspan 18.3m
    length 30.1m
    height 5.7m
    tailHeight 5.7m
  }

  aircraft Hawk_T2 {
    wingspan 9.9m
    length 12.4m
    height 4.0m
    tailHeight 4.0m
  }

  // =========================================================================
  // HANGAR 1 - Large Transport & Heavy Maintenance
  // =========================================================================
  
  hangar HeavyMaintenanceHangar {
    doorWidth 50.0m
    doorHeight 18.0m
    grid baygrid {
      bay HM_Bay1 {
        width 45.0m
        depth 55.0m
        height 18.0m
        adjacent { HM_Bay2 }
      }
      bay HM_Bay2 {
        width 45.0m
        depth 55.0m
        height 18.0m
        adjacent { HM_Bay1 HM_Bay3 }
      }
      bay HM_Bay3 {
        width 45.0m
        depth 55.0m
        height 18.0m
        adjacent { HM_Bay2 }
      }
    }
  }

  // =========================================================================
  // HANGAR 2 - Fighter Maintenance
  // =========================================================================
  
  hangar FighterMaintenanceHangar {
    doorWidth 25.0m
    doorHeight 8.0m
    grid baygrid {
      bay FM_Bay1 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { FM_Bay2 }
      }
      bay FM_Bay2 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { FM_Bay1 FM_Bay3 }
      }
      bay FM_Bay3 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { FM_Bay2 FM_Bay4 }
      }
      bay FM_Bay4 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { FM_Bay3 FM_Bay5 }
      }
      bay FM_Bay5 {
        width 20.0m
        depth 25.0m
        height 8.0m
        adjacent { FM_Bay4 }
      }
    }
  }

  // =========================================================================
  // HANGAR 3 - Rotary Wing Hangar
  // =========================================================================
  
  hangar RotaryWingHangar {
    doorWidth 30.0m
    doorHeight 10.0m
    grid baygrid {
      bay RW_Bay1 {
        width 25.0m
        depth 35.0m
        height 10.0m
        adjacent { RW_Bay2 }
      }
      bay RW_Bay2 {
        width 25.0m
        depth 35.0m
        height 10.0m
        adjacent { RW_Bay1 RW_Bay3 }
      }
      bay RW_Bay3 {
        width 25.0m
        depth 35.0m
        height 10.0m
        adjacent { RW_Bay2 RW_Bay4 }
      }
      bay RW_Bay4 {
        width 25.0m
        depth 35.0m
        height 10.0m
        adjacent { RW_Bay3 }
      }
    }
  }

  // =========================================================================
  // HANGAR 4 - Quick Turnaround & Light Maintenance
  // =========================================================================
  
  hangar QuickTurnaroundHangar {
    doorWidth 15.0m
    doorHeight 6.0m
    grid baygrid {
      bay QT_Bay1 {
        width 12.0m
        depth 18.0m
        height 6.0m
        adjacent { QT_Bay2 }
      }
      bay QT_Bay2 {
        width 12.0m
        depth 18.0m
        height 6.0m
        adjacent { QT_Bay1 QT_Bay3 }
      }
      bay QT_Bay3 {
        width 12.0m
        depth 18.0m
        height 6.0m
        adjacent { QT_Bay2 }
      }
    }
  }

  // =========================================================================
  // SCHEDULED MANUAL INDUCTIONS - Week of December 11-15, 2025
  // =========================================================================

  // Monday Morning - Heavy Transport Maintenance
  induct C130_Hercules into HM_Bay1 HM_Bay2 from 2025-12-11T06:00 to 2025-12-11T18:00;
  induct A400M_Atlas into HM_Bay3 from 2025-12-11T08:00 to 2025-12-13T16:00;

  // Monday - Fighter Operations
  induct F35_Lightning into FM_Bay1 from 2025-12-11T07:00 to 2025-12-11T15:00;
  induct Typhoon_FGR4 into FM_Bay2 from 2025-12-11T08:00 to 2025-12-11T16:00;
  induct F35_Lightning into FM_Bay3 from 2025-12-11T09:00 to 2025-12-11T17:00;
  
  // Monday - Rotary Wing Scheduled Maintenance
  induct Apache_AH64 into RW_Bay1 from 2025-12-11T06:00 to 2025-12-11T14:00;
  induct Chinook_HC6 into RW_Bay2 RW_Bay3 from 2025-12-11T07:00 to 2025-12-12T19:00;

  // Monday - Quick Turnaround
  induct Hawk_T2 into QT_Bay1 from 2025-12-11T08:00 to 2025-12-11T12:00;
  induct Hawk_T2 into QT_Bay2 from 2025-12-11T09:00 to 2025-12-11T13:00;

  // Tuesday Afternoon - Fighter Rotation
  induct Typhoon_FGR4 into FM_Bay4 from 2025-12-12T13:00 to 2025-12-12T21:00;
  induct F35_Lightning into FM_Bay5 from 2025-12-12T14:00 to 2025-12-12T22:00;

  // Wednesday - Extended Maintenance
  induct Apache_AH64 into RW_Bay4 from 2025-12-13T06:00 to 2025-12-13T18:00;
  induct Hawk_T2 into QT_Bay3 from 2025-12-13T10:00 to 2025-12-13T14:00;

  // Thursday - Heavy Day
  induct C130_Hercules into HM_Bay1 from 2025-12-14T06:00 to 2025-12-14T20:00;
  induct Chinook_HC6 into RW_Bay1 RW_Bay2 from 2025-12-14T08:00 to 2025-12-14T20:00;
  induct Typhoon_FGR4 into FM_Bay1 from 2025-12-14T07:00 to 2025-12-14T15:00;
  induct F35_Lightning into FM_Bay2 from 2025-12-14T08:00 to 2025-12-14T16:00;

  // Friday - Week Close
  induct Apache_AH64 into RW_Bay3 from 2025-12-15T06:00 to 2025-12-15T14:00;
  induct Hawk_T2 into QT_Bay1 from 2025-12-15T08:00 to 2025-12-15T12:00;
  induct Hawk_T2 into QT_Bay2 from 2025-12-15T13:00 to 2025-12-15T17:00;

  // =========================================================================
  // AUTO-SCHEDULED INDUCTIONS - System will find optimal slots
  // =========================================================================

  // Emergency maintenance requests
  auto-induct F35_Lightning duration 480 minutes prefer FighterMaintenanceHangar;
  auto-induct Typhoon_FGR4 duration 360 minutes prefer FighterMaintenanceHangar;
  
  // Routine inspections
  auto-induct Hawk_T2 duration 180 minutes prefer QuickTurnaroundHangar;
  auto-induct Hawk_T2 duration 240 minutes prefer QuickTurnaroundHangar;
  
  // Rotary wing service
  auto-induct Apache_AH64 duration 420 minutes prefer RotaryWingHangar;
  auto-induct Chinook_HC6 duration 720 minutes prefer RotaryWingHangar;
  
  // Heavy transport check
  auto-induct C130_Hercules duration 600 minutes prefer HeavyMaintenanceHangar;
}
