// =============================================================================
// non-standard-layout.air
//
// Demonstrates L-shaped hangar layout with explicit adjacency and access links.
//
// Background
// ----------
// Real hangars are often not rectangular.  This file models an L-shaped hangar
// where a horizontal leg (Bay1–Bay2–Bay3) meets a vertical leg (Bay4–Bay5).
// Because the shape cannot be expressed as a simple m×n grid, bay adjacency is
// declared explicitly using the `adjacent` keyword.
//
// Physical layout (top-down view):
//
//   [Bay1] ←→ [Bay2] ←→ [Bay3]
//                          ↕
//                        [Bay4]
//                          ↕
//                        [Bay5]
//
// The door (MainDoor) is at the Bay1 end of the horizontal leg.
// Bay4 and Bay5 can ONLY be reached by passing through Bay3 (the corner).
//
// Access path (sequential tow route from door to each bay area):
//
//   Apron ↔ LShapeEntry → Bay1Node ↔ Bay2Node ↔ Bay3Node → Bay4Node → Bay5Node
//
// Key topological property: Bay4Node and Bay5Node are unreachable when Bay3Node
// is blocked (occupied by a concurrent induction).
//
// Inductions
// ----------
//   VALID_B1       →  Bay1 only, single-bay  →  No errors ✓
//   VALID_CORNER   →  Bay3 + Bay4 (adjacent at the corner)  →  No errors ✓
//   CONT_FAIL      →  Bay1 + Bay3 (non-adjacent: Bay2 lies between them)
//                     Expected: [SFR13_CONTIGUITY] ✗
//   BLOCK_CORNER   →  Bay3 only, 08:00–16:00  (occupies the corner bay)
//   BLOCK_DEEP     →  Bay4 + Bay5, 10:00–18:00 (overlaps BLOCK_CORNER)
//                     Expected: [SFR_DYNAMIC_REACHABILITY] Bay4, Bay5 unreachable
//                     because Bay3 is occupied by BLOCK_CORNER (overlap 10:00–16:00) ✗
// =============================================================================

airfield LShapeDemo {

    // -------------------------------------------------------------------------
    // Clearance envelope — minimal margins for light aircraft
    // -------------------------------------------------------------------------
    clearance MinClearance {
        lateralMargin      0.5 m
        longitudinalMargin 1.0 m
        verticalMargin     0.5 m
    }

    // -------------------------------------------------------------------------
    // Aircraft: LightTransport (fits comfortably in any single bay)
    //   effectiveWingspan = 14.0 + 0.5 = 14.5 m  ≤  15 m bay width ✓
    //   effectiveLength   = 18.0 + 1.0 = 19.0 m  ≤  22 m bay depth ✓
    //   effectiveHeight   =  5.0 + 0.5 =  5.5 m  ≤   7 m bay height ✓
    //
    //   SFR25: ceil(14.5 / 15) = 1 bay minimum → no multi-bay warning on any induction
    // -------------------------------------------------------------------------
    aircraft LightTransport {
        wingspan  14.0 m
        length    18.0 m
        height     5.0 m
        tailHeight  5.0 m
        clearance MinClearance
    }

    // -------------------------------------------------------------------------
    // Access path modelling the L-shaped tow route.
    //
    // Apron (public taxiway, bidirectional)
    //   ↕
    // LShapeEntry  (hangar door threshold)
    //   ↓  (unidirectional tow into hangar — no reverse out past door in model)
    // Bay1Node  ↔  Bay2Node  ↔  Bay3Node  (horizontal leg, bidirectional)
    //                              ↓        (corner turn — unidirectional from here)
    //                           Bay4Node  →  Bay5Node
    //
    // Consequence: Bay3Node is a chokepoint — its removal cuts off Bay4 and Bay5.
    // -------------------------------------------------------------------------
    accessPath LShapePath {
        nodes {
            node Apron        width 30.0 m clearanceHeight  8.0 m
            node LShapeEntry  width 16.0 m clearanceHeight  7.0 m
            node Bay1Node     width 15.0 m clearanceHeight  6.5 m
            node Bay2Node     width 15.0 m clearanceHeight  6.5 m
            node Bay3Node     width 15.0 m clearanceHeight  6.5 m
            node Bay4Node     width 15.0 m clearanceHeight  6.5 m
            node Bay5Node     width 15.0 m clearanceHeight  6.5 m
        }
        links {
            link Apron       to LShapeEntry  bidirectional true type taxi
            link LShapeEntry to Bay1Node                       type tow
            link Bay1Node    to Bay2Node     bidirectional true type tow
            link Bay2Node    to Bay3Node     bidirectional true type tow
            link Bay3Node    to Bay4Node                       type tow
            link Bay4Node    to Bay5Node                       type tow
        }
    }

    // -------------------------------------------------------------------------
    // Hangar: LShapeHangar
    //
    // Door: MainDoor  16 m × 7 m — fits LightTransport effective (14.5 m × 5.5 m) ✓
    //
    // Bay dimensions (each bay: 15 m wide, 22 m deep, 7 m tall)
    //   SFR12 width:  14.5 m ≤ 15 m ✓
    //   SFR12 depth:  19.0 m ≤ 22 m ✓
    //   SFR12 height:  5.5 m ≤  7 m ✓
    //
    // Adjacency (explicit, no grid coordinates — L-shape cannot be a rectangle):
    //   Bay1 ↔ Bay2 ↔ Bay3 ↔ Bay4 ↔ Bay5  (linear chain with a 90° turn at Bay3)
    // -------------------------------------------------------------------------
    hangar LShapeHangar {
        doors {
            door MainDoor {
                width  16.0 m
                height  7.0 m
                accessNode LShapeEntry
            }
        }
        grid baygrid {
            // Horizontal leg
            bay Bay1 {
                width  15.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay2 }
                accessNode Bay1Node
            }
            bay Bay2 {
                width  15.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay1 Bay3 }
                accessNode Bay2Node
            }
            // Corner bay — connects horizontal leg to vertical leg
            bay Bay3 {
                width  15.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay2 Bay4 }
                accessNode Bay3Node
            }
            // Vertical leg
            bay Bay4 {
                width  15.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay3 Bay5 }
                accessNode Bay4Node
            }
            bay Bay5 {
                width  15.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay4 }
                accessNode Bay5Node
            }
        }
    }

    // -------------------------------------------------------------------------
    // VALID_B1 — single aircraft in Bay1 (the first bay in the horizontal leg).
    //
    // All validators pass:
    //   SFR11 (door fit):     14.5 m ≤ 16 m ✓
    //   SFR12 (bay fit):      LightTransport fits Bay1 ✓
    //   SFR13 (contiguity):   single bay, no check needed ✓
    //   SFR_DYNAMIC_REACH:    Bay1 is directly reachable from LShapeEntry ✓
    // -------------------------------------------------------------------------
    induct id "VALID_B1" LightTransport into LShapeHangar bays Bay1 via MainDoor
        from 2024-07-01T08:00
        to   2024-07-01T16:00
        meta {
            note: "Single_bay_at_the_entrance_of_the_horizontal_leg"
        };

    // -------------------------------------------------------------------------
    // VALID_CORNER — two bays spanning the L-corner (Bay3 and Bay4).
    //
    // Bay3 and Bay4 are declared adjacent → contiguous ✓
    // Both are reachable from MainDoor (via Bay1Node → Bay2Node → Bay3Node → Bay4Node) ✓
    // -------------------------------------------------------------------------
    induct id "VALID_CORNER" LightTransport into LShapeHangar bays Bay3 Bay4 via MainDoor
        from 2024-07-02T08:00
        to   2024-07-02T16:00
        meta {
            note: "Valid_2-bay_induction_spanning_the_L-corner"
        };

    // -------------------------------------------------------------------------
    // CONT_FAIL — Bay1 and Bay3 assigned, skipping Bay2 (which lies between them).
    //
    // Adjacency check within the assigned set {Bay1, Bay3}:
    //   Bay1's declared neighbours: {Bay2} — Bay2 not in assigned set
    //   Bay3's declared neighbours: {Bay2, Bay4} — neither in assigned set
    //   BFS from Bay1 within assigned: reaches {Bay1} only → Bay3 unreachable
    //
    // Expected VIOLATION:
    //   [SFR13_CONTIGUITY] Bays Bay1, Bay3 are not contiguous (1/2 reachable).
    //
    // No time overlap with other inductions on this day → no dynamic reachability issue.
    // -------------------------------------------------------------------------
    induct id "CONT_FAIL" LightTransport into LShapeHangar bays Bay1 Bay3 via MainDoor
        from 2024-07-03T08:00
        to   2024-07-03T16:00
        meta {
            note: "VIOLATION — Bay1_and_Bay3_not_adjacent_Bay2_is_missing_SFR13"
        };

    // -------------------------------------------------------------------------
    // BLOCK_CORNER — occupies Bay3 (the corner bay) from 08:00 to 16:00.
    //
    // No errors on its own:
    //   SFR12: LightTransport fits Bay3 ✓
    //   SFR_DYNAMIC_REACH: Bay3 is reachable from MainDoor (via Bay1→Bay2→Bay3) ✓
    //
    // Side-effect: While Bay3 is occupied, Bay4 and Bay5 are cut off from the door.
    // -------------------------------------------------------------------------
    induct id "BLOCK_CORNER" LightTransport into LShapeHangar bays Bay3 via MainDoor
        from 2024-07-04T08:00
        to   2024-07-04T16:00
        meta {
            note: "Occupies_corner_bay_blocking_access_to_the_vertical_leg"
        };

    // -------------------------------------------------------------------------
    // BLOCK_DEEP — wants Bay4 and Bay5 during 10:00–18:00, overlapping BLOCK_CORNER.
    //
    // Overlap window with BLOCK_CORNER: 10:00–16:00.
    // During that window, Bay3Node is blocked (occupied by BLOCK_CORNER).
    // BFS from LShapeEntry with Bay3Node blocked:
    //   LShapeEntry → Bay1Node → Bay2Node → Bay3Node (BLOCKED) → stop
    //   Bay4Node and Bay5Node are unreachable.
    //
    // Expected VIOLATION:
    //   [SFR_DYNAMIC_REACHABILITY] Bays [Bay4, Bay5] are unreachable from
    //   door(s) [MainDoor] because 'Bay3' is occupied by induction
    //   'BLOCK_CORNER' (LightTransport) during the overlap window.
    //
    // Bay3 and Bay4 are adjacent (SFR13 passes for the Bay4+Bay5 assignment) ✓
    // -------------------------------------------------------------------------
    induct id "BLOCK_DEEP" LightTransport into LShapeHangar bays Bay4 Bay5 via MainDoor
        from 2024-07-04T10:00
        to   2024-07-04T18:00
        meta {
            note: "VIOLATION — Bay4_Bay5_unreachable_while_BLOCK_CORNER_holds_Bay3"
        };
}
