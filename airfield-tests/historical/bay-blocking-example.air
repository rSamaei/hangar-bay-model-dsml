// =============================================================================
// bay-blocking-example.air
//
// Demonstrates SFR_DYNAMIC_REACHABILITY: bay access blocked at runtime.
//
// Scenario
// --------
// SequentialHangar has two bays laid out in a linear chain behind a single door:
//
//   [MainDoor] ──tow──> [Bay1] ──tow──> [Bay2]
//
// To reach Bay2, a tow vehicle MUST pass through the Bay1 area.
// When Bay1 is occupied by an aircraft, Bay2 becomes unreachable.
//
// Two inductions compete for the hangar during an overlapping time window:
//
//   IND001  occupies Bay1  from 08:00 to 16:00  (the blocker)
//   IND002  wants    Bay2  from 10:00 to 18:00  (the blocked)
//
// Expected diagnostics
// --------------------
//   IND002  →  [SFR_DYNAMIC_REACHABILITY] Bay2 is unreachable because Bay1 is
//              occupied by IND001 during the 10:00–16:00 overlap window.
//   IND001  →  No reachability error (Bay1 is directly behind the door).
// =============================================================================

airfield SequentialBayDemo {

    // -------------------------------------------------------------------------
    // Clearance envelope
    // -------------------------------------------------------------------------
    clearance StdClearance {
        lateralMargin      1.5 m
        longitudinalMargin 2.0 m
        verticalMargin     1.0 m
    }

    // -------------------------------------------------------------------------
    // Aircraft: FighterJet
    //   effectiveWingspan = 11.0 + 1.5 = 12.5 m
    //   effectiveLength   = 16.0 + 2.0 = 18.0 m
    //   effectiveHeight   =  5.5 + 1.0 =  6.5 m
    // -------------------------------------------------------------------------
    aircraft FighterJet {
        wingspan  11.0 m
        length    16.0 m
        height     5.5 m
        tailHeight  5.5 m
        clearance StdClearance
    }

    // -------------------------------------------------------------------------
    // Access path — sequential chain modelling the physical tow route.
    //
    // Apron (public taxiway, bidirectional)
    //   ↕
    // TaxiIn (hangar threshold / door node)
    //   ↓  (unidirectional tow into hangar)
    // Bay1Node (access node for Bay1)
    //   ↓  (unidirectional — must pass through Bay1 to reach Bay2)
    // Bay2Node (access node for Bay2)
    //
    // Key property: Bay2Node is ONLY reachable via Bay1Node.
    // -------------------------------------------------------------------------
    accessPath SequentialPath {
        nodes {
            node Apron    width 30.0 m clearanceHeight 10.0 m
            node TaxiIn   width 15.0 m clearanceHeight  8.0 m
            node Bay1Node width 14.0 m clearanceHeight  7.0 m
            node Bay2Node width 14.0 m clearanceHeight  7.0 m
        }
        links {
            link Apron    to TaxiIn   bidirectional true type taxi
            link TaxiIn   to Bay1Node                    type tow
            link Bay1Node to Bay2Node                    type tow
        }
    }

    // -------------------------------------------------------------------------
    // Hangar: SequentialHangar
    //   Door:  MainDoor  (14 m × 7 m) — fits FighterJet (12.5 m × 6.5 m effective) ✓
    //   Bay1:  14 m × 22 m × 7 m     — fits FighterJet ✓ (SFR12 passes)
    //   Bay2:  14 m × 22 m × 7 m     — fits FighterJet ✓ (SFR12 passes)
    // -------------------------------------------------------------------------
    hangar SequentialHangar {
        doors {
            door MainDoor {
                width  14.0 m
                height  7.0 m
                // Hooks this door to the TaxiIn access node
                accessNode TaxiIn
            }
        }
        grid baygrid {
            bay Bay1 {
                width  14.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay2 }
                // Hooks Bay1 to the first access node in the chain
                accessNode Bay1Node
            }
            bay Bay2 {
                width  14.0 m
                depth  22.0 m
                height  7.0 m
                adjacent { Bay1 }
                // Hooks Bay2 to the terminal access node (only reachable via Bay1Node)
                accessNode Bay2Node
            }
        }
    }

    // -------------------------------------------------------------------------
    // IND001 — occupies Bay1 (the gate bay) for a full day shift.
    //
    // No validator errors expected:
    //   SFR11 (door fit):   FighterJet 12.5 m ≤ 14 m door ✓
    //   SFR12 (bay fit):    FighterJet 12.5 m × 18 m × 6.5 m fits Bay1 ✓
    //   SFR25 (bay count):  ceil(12.5 / 14) = 1 bay required, 1 assigned ✓
    //   SFR_DYNAMIC_REACHABILITY: Bay1 is directly behind the door — always reachable ✓
    // -------------------------------------------------------------------------
    induct id "IND001" FighterJet into SequentialHangar bays Bay1 via MainDoor
        from 2024-06-01T08:00
        to   2024-06-01T16:00
        meta {
            squadron:    "3 Squadron"
            maintenance: "Minor_Service"
            note:        "Occupies_gate_bay_blocking_access_to_Bay2"
        };

    // -------------------------------------------------------------------------
    // IND002 — wants Bay2 during a window that overlaps with IND001 (10:00–16:00).
    //
    // Expected VIOLATION:
    //   [SFR_DYNAMIC_REACHABILITY] Bay2 is unreachable from door [MainDoor]
    //   because 'Bay1' is occupied by induction 'IND001' (FighterJet)
    //   during 2024-06-01T10:00:00.000Z to 2024-06-01T16:00:00.000Z.
    //
    // Explanation: The BFS from TaxiIn reaches Bay1Node but cannot proceed to
    // Bay2Node because Bay1Node is blocked by IND001. Bay2 becomes unreachable.
    // -------------------------------------------------------------------------
    induct id "IND002" FighterJet into SequentialHangar bays Bay2 via MainDoor
        from 2024-06-01T10:00
        to   2024-06-01T18:00
        meta {
            squadron:    "29 Squadron"
            maintenance: "A_Check"
            note:        "BLOCKED — cannot_reach_Bay2_while_IND001_occupies_Bay1"
        };
}
