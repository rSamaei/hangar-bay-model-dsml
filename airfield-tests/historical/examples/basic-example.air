airfield RAF_Coningsby {
    // Define clearance envelopes
    clearance StandardSafety {
        lateralMargin 2.0 m
        longitudinalMargin 3.0 m
        verticalMargin 1.5 m
    }

    clearance TightFit {
        lateralMargin 0.5 m
        longitudinalMargin 1.0 m
        verticalMargin 0.5 m
    }

    // Define aircraft types
    aircraft Typhoon {
        wingspan 10.95 m
        length 15.96 m
        height 5.28 m
        tailHeight 5.28 m
        clearance StandardSafety
    }

    aircraft F35B {
        wingspan 10.7 m
        length 15.6 m
        height 4.36 m
        tailHeight 4.36 m
        clearance StandardSafety
    }

    // Define access paths
    accessPath MainAccess {
        nodes {
            node Apron width 50.0 m clearanceHeight 8.0 m
            node HangarThreshold width 15.0 m clearanceHeight 7.0 m
            node Bay1Entry width 12.0 m clearanceHeight 6.0 m
            node Bay2Entry width 12.0 m clearanceHeight 6.0 m
        }
        links {
            link Apron to HangarThreshold bidirectional true type taxi
            link HangarThreshold to Bay1Entry type tow
            link HangarThreshold to Bay2Entry type tow
        }
    }

    // Define hangar with grid
    hangar MainHangar {
        doors {
            door MainDoor {
                width 15.0 m
                height 7.0 m
                accessNode HangarThreshold
            }
        }
        grid baygrid {
            rows 2 cols 2
            bay Bay1A {
                at row 0 col 0
                width 20.0 m
                depth 25.0 m
                height 8.0 m
                adjacent { Bay1B Bay2A }
                accessNode Bay1Entry
            }
            bay Bay1B {
                at row 0 col 1
                width 20.0 m
                depth 25.0 m
                height 8.0 m
                adjacent { Bay1A Bay2B }
            }
            bay Bay2A {
                at row 1 col 0
                width 20.0 m
                depth 25.0 m
                height 8.0 m
                adjacent { Bay1A Bay2B }
                accessNode Bay2Entry
            }
            bay Bay2B {
                at row 1 col 1
                width 20.0 m
                depth 25.0 m
                height 8.0 m
                adjacent { Bay1B Bay2A }
            }
        }
    }

    // Manual inductions
    induct id "IND001" Typhoon into MainHangar bays Bay1A via MainDoor 
        from 2024-01-15T08:00 to 2024-01-15T16:00
        meta {
            priority: "high"
            squadron: "29 Squadron"
        };

    induct id "IND002" F35B into MainHangar bays Bay2A 
        from 2024-01-15T10:00 to 2024-01-15T18:00
        meta {
            priority: "medium"
            squadron: "617 Squadron"
        };
}