{
  "name": "@airfield/simulator",
  "version": "1.0.0",
  "type": "module",
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js"
    },
    "./analysis": {
      "types": "./out/analysis.d.ts",
      "import": "./out/analysis.js"
    },
    "./scheduler": {
      "types": "./out/scheduler.d.ts",
      "import": "./out/scheduler.js"
    },
    "./builders/*": {
      "types": "./out/builders/*.d.ts",
      "import": "./out/builders/*.js"
    },
    "./types/*": {
      "types": "./out/types/*.d.ts",
      "import": "./out/types/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "~3.1.3"
  }
}
